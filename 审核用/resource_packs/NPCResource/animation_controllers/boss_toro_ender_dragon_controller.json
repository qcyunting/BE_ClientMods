{
  "format_version": "1.17.0",
  "animation_controllers": {
    "controller.animation.toro_ender_dragon.root": {
      "initial_state": "spawn",
      "states": {
        "spawn": {
          "animations": ["spawn"],
          "transitions": [
            { "idle_ground": "query.is_on_ground" },
            { "fly_idle": "!query.is_on_ground" }
          ]
        },

        "idle_ground": {
          "animations": ["idle"],
          "transitions": [
            { "walk": "query.is_moving && query.is_on_ground" },
            { "fly_idle": "!query.is_on_ground" },
            { "attack_state": "query.mod.is_attacking == 1.0" },
            { "death": "query.mod.is_dead == 1.0" }
          ]
        },

        "walk": {
          "animations": ["walk"],
          "transitions": [
            { "idle_ground": "!query.is_moving && query.is_on_ground" },
            { "fly_idle": "!query.is_on_ground" },
            { "attack_state": "query.mod.is_attacking == 1.0" }
          ]
        },

        "fly_idle": {
          "animations": ["fly_idle"],
          "transitions": [
            { "fly": "query.is_moving && !query.is_on_ground" },
            { "idle_ground": "query.is_on_ground" },
            { "fly_attack_state": "query.mod.is_attacking == 1.0" },
            { "fly_drop": "query.mod.is_dropping == 1.0" },
            { "fly_rushdrop": "query.mod.is_rush_dropping == 1.0" },
            { "fly_roar": "query.mod.is_roaring == 1.0" },
            { "fly_spit": "query.mod.is_spitting == 1.0" },
            { "death": "query.mod.is_dead == 1.0" }
          ]
        },

        "fly": {
          "animations": ["fly"],
          "transitions": [
            { "fly_idle": "!query.is_moving && !query.is_on_ground" },
            { "idle_ground": "query.is_on_ground" }
          ]
        },

        "fly_drop": {
          "animations": ["fly_drop"],
          "transitions": [
            { "fly_idle": "query.mod.is_dropping != 1.0" }
          ]
        },

        "fly_rushdrop": {
          "animations": ["fly_rushdrop"],
          "transitions": [
            { "fly_idle": "query.mod.is_rush_dropping != 1.0" }
          ]
        },

        "fly_roar": {
          "animations": ["fly_roar"],
          "transitions": [
            { "fly_idle": "query.mod.is_roaring != 1.0" }
          ]
        },

        "fly_spit": {
          "animations": ["fly_spit"],
          "transitions": [
            { "fly_idle": "query.mod.is_spitting != 1.0" }
          ]
        },

        "attack_state": {
          "animations": ["stand"],
          "transitions": [
            { "attack_two_claw_smash": "query.mod.attack_type == 1.0" },
            { "attack_claw_swipe": "query.mod.attack_type == 2.0" },
            { "attack_fire": "query.mod.attack_type == 3.0" },
            { "attack_tail_swipe": "query.mod.attack_type == 4.0" },
            { "attack_left_claw": "query.mod.attack_type == 5.0" },
            { "attack_left_smash": "query.mod.attack_type == 6.0" },
            { "attack_right_claw": "query.mod.attack_type == 7.0" },
            { "attack_right_smash": "query.mod.attack_type == 8.0" },
            { "attack_moveback_smash": "query.mod.attack_type == 9.0" },
            { "attack_moveback_spit": "query.mod.attack_type == 10.0" },
            { "idle_ground": "query.mod.attack_finished == 1.0" }
          ]
        },

        "attack_two_claw_smash": {
          "animations": ["two_claw_smash"],
          "transitions": [
            { "idle_ground": "query.mod.attack_finished == 1.0" }
          ]
        },

        "attack_claw_swipe": {
          "animations": ["claw_swipe"],
          "transitions": [
            { "idle_ground": "query.mod.attack_finished == 1.0" }
          ]
        },

        "attack_fire": {
          "animations": ["fire"],
          "transitions": [
            { "idle_ground": "query.mod.attack_finished == 1.0" }
          ]
        },

        "attack_tail_swipe": {
          "animations": ["tail_swipe"],
          "transitions": [
            { "idle_ground": "query.mod.attack_finished == 1.0" }
          ]
        },

        "attack_left_claw": {
          "animations": ["left_claw"],
          "transitions": [
            { "idle_ground": "query.mod.attack_finished == 1.0" }
          ]
        },

        "attack_left_smash": {
          "animations": ["left_smash"],
          "transitions": [
            { "idle_ground": "query.mod.attack_finished == 1.0" }
          ]
        },

        "attack_right_claw": {
          "animations": ["right_claw"],
          "transitions": [
            { "idle_ground": "query.mod.attack_finished == 1.0" }
          ]
        },

        "attack_right_smash": {
          "animations": ["right_smash"],
          "transitions": [
            { "idle_ground": "query.mod.attack_finished == 1.0" }
          ]
        },

        "attack_moveback_smash": {
          "animations": ["moveback_smash"],
          "transitions": [
            { "idle_ground": "query.mod.attack_finished == 1.0" }
          ]
        },

        "attack_moveback_spit": {
          "animations": ["moveback_spit"],
          "transitions": [
            { "idle_ground": "query.mod.attack_finished == 1.0" }
          ]
        },

        "fly_attack_state": {
          "animations": ["stand"],
          "transitions": [
            { "fly_idle": "query.mod.attack_finished == 1.0" }
          ]
        },

        "death": {
          "animations": ["death"],
          "transitions": []
        }
      }
    }
  }
}