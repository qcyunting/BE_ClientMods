    "$size|default": [40, 18],
    "size": "$size",
    "layer": 2,
    "keep_ratio": false,
    "texture": "textures/ui/White",
    "color": [0.18, 0.57, 0.36],
    "controls": [
      {"toggleText": {"type": "label", "layer": 3, "color": [0.96, 0.97, 0.98], "text": "$text"}}
    ]
  },
  "filter_unchecked_state": {
    "type": "image",
    "$text|default": "",
    "$size|default": [40, 18],
    "size": "$size",
    "layer": 1,
    "keep_ratio": false,
    "texture": "textures/ui/White",
    "color": [0.22, 0.24, 0.29],
    "controls": [
      {"toggleText": {"type": "label", "layer": 3, "color": [0.76, 0.78, 0.82], "text": "$text"}}
    ]
  },
  "isHasTypeToggleBtn@common.toggle": {
    "$checked_control": "dressing_room.filter_checked_state",
    "$checked_hover_control": "dressing_room.filter_checked_state",
    "$checked_locked_control": "dressing_room.filter_checked_state",
    "$checked_locked_hover_control": "dressing_room.filter_checked_state",
    "$unchecked_control": "dressing_room.filter_unchecked_state",
    "$unchecked_hover_control": "dressing_room.filter_unchecked_state",
    "$unchecked_locked_control": "dressing_room.filter_unchecked_state",
    "$unchecked_locked_hover_control": "dressing_room.filter_unchecked_state",
    "$radio_toggle_group": true,
    "$size|default": [40, 18],
    "$toggle_group_default_selected": 0,
    "$toggle_name": "#isHasType",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "size": "$size"
  },
  "move_tab_btn_selection": {
    "anim_type": "offset",
    "duration": 0.1,
    "from": [0, 0],
    "to": [0, 0]
  }
}
