{
  "format_version": "1.17.0",
  "animation_controllers": {
    "controller.animation.target_dummy.root": {
      "initial_state": "spawning",
      "states": {
        "spawning": {
          "transitions": [{"idle": "query.any_animation_finished"}],
          "animations": ["spawn"],
          "blend_transition": 0.0
        },
        "idle": {
          "transitions": [
            {"hurt": "query.variant > 0"},
            {"death": "query.health <= 1"}
          ],
          "animations": ["idle"],
          "blend_transition": 0.0
        },
        "hurt": {
          "transitions": [
            {"hurt1": "math.random(0,3) == 0"},
            {"hurt2": "math.random(0,3) == 1"},
            {"hurt3": "math.random(0,3) == 2"},
            {"hurt4": "true"}
          ],
          "animations": ["idle"],
          "blend_transition": 0.0
        },
        "hurt1": {
          "transitions": [{"idle": "query.any_animation_finished"}],
          "animations": ["hurt1"],
          "blend_transition": 0.0
        },
        "hurt2": {
          "transitions": [{"idle": "query.any_animation_finished"}],
          "animations": ["hurt2"],
          "blend_transition": 0.0
        },
        "hurt3": {
          "transitions": [{"idle": "query.any_animation_finished"}],
          "animations": ["hurt3"],
          "blend_transition": 0.0
        },
        "hurt4": {
          "transitions": [{"idle": "query.any_animation_finished"}],
          "animations": ["hurt4"],
          "blend_transition": 0.0
        },
        "death": {
          "transitions": [],
          "animations": ["death"],
          "blend_transition": 0.0
        }
      }
    }
  }
}